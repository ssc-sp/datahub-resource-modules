{
  "variable": {
    "databricks_admin_users": {
      "type": "list(any)",
      "default": []
    },
    "databricks_project_lead_users": {
      "type": "list(any)",
      "default": []
    },
    "databricks_project_users": {
      "type": "list(any)",
      "default": []
    },
    "databricks_project_guests": {
      "type": "list(any)",
      "default": []
    },
    "azure_databricks_enterprise_oid": {
      "type": "string"
    },
    "log_workspace_id": {
      "type": "string",
      "default": ""
    },
    "enable_ml_cluster": {
      "type": "bool",
      "default": false
    },
    "enable_ml_gpu_cluster": {
      "type": "bool",
      "default": false
    },
    "ml_compute": {
      "type": "string",
      "default": "Standard_D4ds_v5"
    },
    "ml_gpu_compute": {
      "type": "string",
      "default": "Standard_NC4as_T4_v3"
    },
    "databricks_metastore_id": {
      "type": "string"
    }
  }
}